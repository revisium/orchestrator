{
  "name": "@revisium/orchestrator",
  "version": "0.0.0",
  "description": "Local orchestrator for software-development tasks driven by short-lived AI agents",
  "keywords": [
    "agents",
    "orchestrator",
    "ai",
    "development",
    "revisium",
    "dbos"
  ],
  "license": "MIT",
  "author": "Anton Kashirov",
  "type": "module",
  "engines": {
    "node": ">=24.11.1 <25"
  },
  "main": "./dist/cli/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revisium/orchestrator.git"
  },
  "bin": {
    "revo": "bin/revo.js"
  },
  "files": [
    "dist/",
    "bin/",
    "control-plane/bootstrap.config.json",
    "revisium.config.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "revo": "tsx src/cli/index.ts",
    "smoke:control-plane": "tsx scripts/smoke-control-plane-data-access.ts",
    "smoke:create-run": "tsx scripts/smoke-create-run.ts",
    "smoke:inspect-run": "tsx scripts/smoke-inspect-run.ts",
    "smoke:step-lifecycle": "tsx scripts/smoke-step-lifecycle.ts",
    "smoke:worker-loop": "tsx scripts/smoke-worker-loop.ts",
    "smoke:claude-runner": "tsx scripts/smoke-claude-runner.ts",
    "smoke:worktree-isolation": "tsx scripts/smoke-worktree-isolation.ts",
    "smoke:pr-poller": "tsx scripts/smoke-pr-poller.ts",
    "smoke:mvp": "tsx scripts/smoke-mvp.ts",
    "test": "tsx --test $(find src -name '*.test.ts' | sort)",
    "test:cov": "mkdir -p coverage && node --import tsx --test --experimental-test-coverage --test-reporter=spec --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=coverage/lcov.info $(find src -name '*.test.ts' | sort)",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:ci": "eslint . --max-warnings 0",
    "sonar:local": "bash scripts/sonar-local.sh",
    "sonar:issues:local": "bash scripts/sonar-issues-local.sh",
    "ci:local:sonar": "bash scripts/ci-local-sonar.sh",
    "verify": "pnpm run typecheck && pnpm run lint:ci && pnpm run test:cov"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "4.19.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@revisium/client": "^0.6.0",
    "@revisium/standalone": "^2.8.2",
    "commander": "^12.1.0",
    "pg": "8.21.0",
    "reflect-metadata": "0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1"
  }
}
