{
  "name": "agent-orchestrator",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.11.1 <25"
  },
  "bin": {
    "revo": "./bin/revo.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "revo": "tsx src/cli/index.ts",
    "smoke:control-plane": "tsx scripts/smoke-control-plane-data-access.ts",
    "smoke:create-run": "tsx scripts/smoke-create-run.ts",
    "smoke:inspect-run": "tsx scripts/smoke-inspect-run.ts",
    "smoke:step-lifecycle": "tsx scripts/smoke-step-lifecycle.ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@revisium/client": "^0.6.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@revisium/standalone": "^2.7.2",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
