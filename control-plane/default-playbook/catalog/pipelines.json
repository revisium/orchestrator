          },
          "planReviewRouter": {
            "id": "planReviewRouter",
            "kind": "choice",
            "branches": [
              {
                "when": {
                  "op": "verdict.in",
                  "value": [
                    "approved",
                    "clean"
                  ]
                },
                "goto": "planGate"
              },
              {
                "when": {
                  "op": "all",
                  "of": [
                    {
                      "op": "verdict.in",
                      "value": [
                        "blocker",
                        "changes_requested"
                      ]
                    },
                    {
                      "op": "counter.lt",
                      "scope": "planReviewLoop",
                      "value": 4
                    }
                  ]
                },
                "goto": "analyst"
              },
              {
                "default": "planStuckGate"
              }
            ]
          },
          "planStuckGate": {
            "id": "planStuckGate",
            "kind": "humanGate",
            "reason": "plan-stuck",
            "outcomes": [
              "approved"
            ],
            "branches": [
              {
                "when": {
                  "op": "verdict.eq",
                  "value": "approved"
                },
                "goto": "developer"
              },
              {
                "default": "blockedEnd"
              }
            ],
            "gatedArtifact": {
              "node": "analyst",
              "as": "plan"
            }
          },
          "planGate": {
            "id": "planGate",
            "kind": "humanGate",
            "reason": "plan-review",
            "outcomes": [
              "approved"
            ],
            "branches": [
              {
                "when": {
                  "op": "verdict.eq",
                  "value": "approved"
                },
                "goto": "developer"
              },
              {
                "default": "blockedEnd"
              }
            ],
            "gatedArtifact": {
              "node": "analyst",
              "as": "plan"
            }
          },
          "developer": {
            "id": "developer",
            "kind": "agent",
            "roleRef": "role:developer",
            "next": "codeReview",
            "onFailure": "abort",
            "resultSchema": "schema:change",
            "consumes": [
              {
                "node": "analyst",
                "as": "plan"
              }
            ],
            "produces": {
              "name": "change"
            }
          },
