            "consumes": [
              {
                "node": "developer",
                "as": "developerChange",
                "staleOk": true
              },
              {
                "node": "reworkDeveloper",
                "as": "reworkChange",
                "optional": true
              }
            ]
          },
          "codeReviewRouter": {
            "id": "codeReviewRouter",
            "kind": "choice",
            "branches": [
