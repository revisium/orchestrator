                  "of": [
                    {
                      "op": "verdict.in",
                      "value": [
                        "blocker",
                        "changes_requested"
                      ]
                    },
                    {
                      "op": "counter.lt",
                      "scope": "codeReviewLoop",
                      "value": 3
                    }
                  ]
                },
                "goto": "reworkDeveloper"
              },
              {
                "default": "codeStuckGate"
              }
            ]
          },
          "codeStuckGate": {
            "id": "codeStuckGate",
            "kind": "humanGate",
            "reason": "code-review-stuck",
