            ]
          },
          "cleanupWorktree": {
            "id": "cleanupWorktree",
            "kind": "script",
            "scriptRef": "script:cleanupWorktree",
            "next": "mergedEnd",
            "resultSchema": "schema:integration"
          },
          "mergedEnd": {
            "id": "mergedEnd",
            "kind": "terminal",
            "status": "succeeded"
          },
          "failedEnd": {
            "id": "failedEnd",
            "kind": "terminal",
            "status": "failed"
          },
          "blockedEnd": {
            "id": "blockedEnd",
            "kind": "terminal",
            "status": "blocked"
          },
          "pollPr": {
            "id": "pollPr",
            "kind": "script",
            "scriptRef": "script:pollPr",
            "next": "prRouter",
            "onFailure": "route",
            "resultSchema": "schema:prFeedback",
            "produces": {
