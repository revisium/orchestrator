            "produces": {
              "name": "change"
            },
            "consumes": [
              {
                "node": "pollPr",
                "as": "feedback"
              },
              {
                "node": "mergeReadiness",
                "as": "mergeFeedback",
                "optional": true,
                "staleOk": true
              },
              {
                "node": "mergeRecheck",
                "as": "recheckFeedback",
                "optional": true,
                "staleOk": true
