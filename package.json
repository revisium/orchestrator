{
  "name": "agent-orchestrator",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.11.1 <25"
  },
  "bin": {
    "revo": "./bin/revo.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "revo": "tsx src/cli/index.ts",
    "smoke:control-plane": "tsx scripts/smoke-control-plane-data-access.ts",
    "smoke:create-run": "tsx scripts/smoke-create-run.ts",
    "smoke:inspect-run": "tsx scripts/smoke-inspect-run.ts",
    "smoke:step-lifecycle": "tsx scripts/smoke-step-lifecycle.ts",
    "smoke:worker-loop": "tsx scripts/smoke-worker-loop.ts",
    "smoke:claude-runner": "tsx scripts/smoke-claude-runner.ts",
    "smoke:worktree-isolation": "tsx scripts/smoke-worktree-isolation.ts",
    "smoke:pr-poller": "tsx scripts/smoke-pr-poller.ts",
    "test": "tsx --test $(find src -name '*.test.ts' | sort)",
    "test:cov": "mkdir -p coverage && node --import tsx --test --experimental-test-coverage --test-reporter=spec --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=coverage/lcov.info $(find src -name '*.test.ts' | sort)",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:ci": "eslint . --max-warnings 0",
    "sonar:local": "bash scripts/sonar-local.sh",
    "sonar:issues:local": "bash scripts/sonar-issues-local.sh",
    "ci:local:sonar": "bash scripts/ci-local-sonar.sh",
    "verify": "npm run typecheck && npm run lint:ci && npm run test:cov"
  },
  "dependencies": {
    "@revisium/client": "^0.6.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@revisium/standalone": "^2.7.2",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1"
  }
}
