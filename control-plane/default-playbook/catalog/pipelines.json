            "resultSchema": "schema:plan",
            "produces": {
              "name": "plan"
            },
            "incrementCounters": [
              "planReviewLoop"
            ]
          },
          "planReviewer": {
            "id": "planReviewer",
            "kind": "agent",
            "roleRef": "role:reviewer",
            "next": "planReviewRouter",
            "onFailure": "abort",
            "resultSchema": "schema:reviewVerdict",
            "consumes": [
              {
