            "onFailure": "abort",
            "resultSchema": "schema:change",
            "incrementCounters": [
              "codeReviewLoop"
            ],
            "produces": {
              "name": "change"
            }
          },
          "integrator": {
            "id": "integrator",
            "kind": "script",
            "scriptRef": "script:integrator",
            "next": "pollPr",
